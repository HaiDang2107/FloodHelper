# Database Configuration
DB_HOST="localhost"
DB_PORT=5432
DB_NAME="floodhelper"
DB_USER="floodhelper_user"
DB_PASSWORD="floodhelper_password"
DB_SCHEMA="public"

# For Docker: DB_HOST="postgres"

# Full DATABASE_URL (constructed from above variables)
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=${DB_SCHEMA}"

# Redis Configuration
REDIS_HOST="localhost"
REDIS_PORT=6379

# For Docker: REDIS_HOST="redis"

EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER="234@hmail.com"
EMAIL_PASSWORD="ssss"
EMAIL_CONNECTION_TIMEOUT_MS=10000
EMAIL_GREETING_TIMEOUT_MS=10000
EMAIL_SOCKET_TIMEOUT_MS=20000

# Firebase
FIREBASE_PROJECT_ID="your-project-id-here"
FIREBASE_PRIVATE_KEY="your-private-key-here"
FIREBASE_CLIENT_EMAIL="your-client-email-here"

TTL_OTP=300000

# JWT
AT_SECRET="your-access-token-secret-here"
RT_SECRET="your-refresh-token-secret-here"

# JWT Expiration Times
AT_EXPIRES_IN="15m"
RT_EXPIRES_IN="7d"

VIETQR_USERNAME="abcd"
VIETQR_PASSWORD="abcd"
MY_USERNAME="abcd"
MY_PASSWORD="abcd"


# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# Application
NODE_ENV="development"
PORT=3000
MQTT_SERVICE_TOKEN="replace_with_mqtt_service_bearer_token"

# Email (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# File Upload (optional)
UPLOAD_DEST="./uploads"
MAX_FILE_SIZE=5242880
