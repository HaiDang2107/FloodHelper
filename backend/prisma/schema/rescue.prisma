// ==============================
// 4. RESCUE MODULE
// ==============================

model Signal {
  signalId     String    @id @default(uuid()) @db.Uuid @map("signal_id")
  createdBy    String    @db.Uuid @map("created_by")
  trappedCount Int       @default(0) @map("trapped_count")
  hasChildren  Boolean   @default(false) @map("has_children")
  hasElderly   Boolean   @default(false) @map("has_elderly")
  hasFood      Boolean   @default(false) @map("has_food")
  note         String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  handledAt    DateTime? @map("handled_at")
  deletedAt    DateTime? @map("deleted_at")

  user User @relation(fields: [createdBy], references: [userId])

  @@map("Signal")
}