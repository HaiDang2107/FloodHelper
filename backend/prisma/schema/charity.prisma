// ==============================
// 3. CHARITY MODULE
// ==============================

model CharityCampaign {
  campaignId           String    @id @default(uuid()) @db.Uuid @map("campaign_id")
  organizedBy          String    @db.Uuid @map("organized_by")
  bankAccountId        String?   @db.Uuid @map("bank_account_id")
  checkedBy            String?   @db.Uuid @map("checked_by")
  requestedAt          DateTime? @map("requested_at")
  respondedAt          DateTime? @map("responded_at")
  noteByAuthority      String?   @map("note_by_authority")
  campaignName         String    @map("campaign_name")
  purpose              String    @db.Text
  destination          String
  campaignLatitude     Decimal?  @map("campaign_latitude") @db.Decimal(10, 7)
  campaignLongitude    Decimal?  @map("campaign_longitude") @db.Decimal(10, 7)
  charityObject        String    @map("charity_object")
  state                String
  startedDonationAt  DateTime? @map("started_donation_at")
  finishedDonationAt DateTime? @map("finished_donation_at")
  startedDistributionAt  DateTime? @map("started_distribution_at")
  finishedDistributionAt DateTime? @map("finished_distribution_at")
  bankStatementFileUrl String?   @map("bank_statement_file_url")
  
  createdAt            DateTime  @default(now()) @map("created_at") 

  organizer         User               @relation("CampaignOrganizer", fields: [organizedBy], references: [userId])
  bankAccount       BankAccount?       @relation(fields: [bankAccountId], references: [bankAccountId])
  checker           User?              @relation("CampaignChecker", fields: [checkedBy], references: [userId])
  transactions      Transaction[]
  supplies          Supply[]
  financialSupports FinancialSupport[]

  @@map("CharityCampaign")
}

model Transaction {
  transactionId             String           @id @default(uuid()) @db.Uuid @map("transaction_id")
  campaignId                String           @db.Uuid @map("campaign_id")
  transType                 String           @default("C") @map("trans_type")
  donateAt                  DateTime         @map("donate_at")
  donatedBy                 String?          @map("donated_by")
  amount                    Decimal          @db.Decimal(15, 2)
  content                   String?
  transactionIdFromVietQR   String?          @map("transaction_id_from_vietqr")
  transactionRefId          String?          @map("transaction_ref_id")
  referencenumber           String?
  qrLink                    String?          @map("qr_link")
  createdAt                 DateTime         @default(now()) @map("created_at")
  transactionTime           DateTime?        @map("transaction_time")
  expiredAt                 DateTime?        @map("expired_at")
  state                     TransactionState @default(CREATED)

  campaign CharityCampaign @relation(fields: [campaignId], references: [campaignId])

  @@map("Transaction")
}

model BankAccount {
  bankAccountId     String @id @default(uuid()) @db.Uuid @map("bank_account_id")
  bankName          String @map("bank_name")
  userBankName      String @map("user_bank_name") @default("UNKNOWN")
  bankCode          String @map("bank_code") @default("UNKNOWN")
  bankAccountNumber String @map("bank_account_number")
  campaigns         CharityCampaign[]

  @@unique([bankName, bankAccountNumber])

  @@map("BankAccount")
}

model Supply {
  supplyId       String   @id @default(uuid()) @db.Uuid @map("supply_id")
  campaignId     String   @db.Uuid @map("campaign_id")
  supplyName     String   @map("supply_name")
  unitPrice      Decimal? @map("unit_price")
  quantity       Int
  price          Decimal
  boughtAt       DateTime @map("bought_at")
  supplyImageUrl String?  @map("supply_image_url")
  invoiceImageUrl String? @map("invoice_image_url")

  campaign CharityCampaign @relation(fields: [campaignId], references: [campaignId])

  @@map("Supply")
}

model AnnouncementFromBenefactor {
  announcementId String @id @default(uuid()) @db.Uuid @map("announcement_id")
  campaignId     String @db.Uuid @map("campaign_id")
  textContent    String? @map("text_content")
  imageUrl       String? @map("image_url")
  
  @@map("AnnouncementFromBenefactor")
}

model FinancialSupport {
  financialSupportId String   @id @default(uuid()) @db.Uuid @map("financial_support_id")
  campaignId         String   @db.Uuid @map("campaign_id")
  householdName      String   @map("household_name")
  amount             Decimal  @db.Decimal(15, 2)
  allocatedAt        DateTime @map("allocated_at")

  campaign CharityCampaign @relation(fields: [campaignId], references: [campaignId])

  @@map("FinancialSupport")
}

enum TransactionState {
  CREATED
  VERIFYING
  SUCCESS
  FAILED
  EXPIRED
}