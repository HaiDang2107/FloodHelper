// ==============================
// 1. AUTH & USER MODULE
// ==============================

model User {
  userId           String    @id @default(uuid()) @db.Uuid @map("user_id")
  fullname         String    @db.VarChar(255)
  nickname         String?   @db.VarChar(255)
  dob              DateTime? @db.Date

  // --- Thay thế placeOfOrigin ---
  originProvinceCode Int?      @map("origin_province_code")
  originProvince     Province? @relation("OriginProvince", fields: [originProvinceCode], references: [code])
  originWardCode Int?      @map("origin_Ward_code")
  originWard     Ward? @relation("OriginWard", fields: [originWardCode], references: [code])

  // --- Thay thế placeOfResidence ---
  residenceProvinceCode Int?      @map("residence_province_code")
  residenceProvince     Province? @relation("ResidenceProvince", fields: [residenceProvinceCode], references: [code])
  residenceWardCode Int?      @map("residence_ward_code")
  residenceWard     Ward? @relation("ResidenceWard", fields: [residenceWardCode], references: [code])

  dateOfIssue      DateTime? @map("date_of_issue") @db.Date
  dateOfExpire     DateTime? @map("date_of_expire") @db.Date
  role             String[]  @default(["NORMAL_USER"]) 
  curLongitude     Decimal?  @map("cur_longitude") @db.Decimal(10, 7)
  curLatitude      Decimal?  @map("cur_latitude") @db.Decimal(10, 7)
  visibilityMode   String    @default("JUST_FRIEND") @map("visibility_mode") @db.VarChar(20) 
  showCharityCampaignLocations Boolean @default(false) @map("show_charity_campaign_locations")
  avatarUrl        String?   @map("avatar_url")
  citizenId        String?   @map("citizen_id")
  gender           String?   @db.VarChar(20)
  phoneNumber      String    @unique @map("phone_number")
  citizenIdCardImg String?   @map("citizen_id_card_img")
  jobPosition      String?   @map("job_position")
  fcmToken         String?   @map("fcm_token")

  // Relations (Giữ nguyên)
  account              Account?
  posts                Post[]
  organizedCampaigns   CharityCampaign[]     @relation("CampaignOrganizer")
  checkedCampaigns     CharityCampaign[]     @relation("CampaignChecker")
  signals              Signal[]              @relation("SignalCreator")
  handledSignals       Signal[]              @relation("SignalHandler")
  sentMessages         Message[]
  createdChatRooms     ChatRoom[]
  likes                Like[]
  comments             Comment[]
  roomMemberships      RoomMember[]
  roleRequestsCreated  RoleUpdatingRequest[] @relation("RoleRequestCreator")
  roleRequestsReceived RoleUpdatingRequest[] @relation("RoleRequestChecker")
  friendRequestsSent   FriendMakingRequest[] @relation("FriendRequestSender")
  friendRequestsRcved  FriendMakingRequest[] @relation("FriendRequestReceiver")
  
  friendshipsInitiated Friendship[]          @relation("Friendship_User") 
  friendshipsReceived  Friendship[]          @relation("Friendship_Friend")

  @@map("User")
}

model Account {
  accountId                String   @id @default(uuid()) @db.Uuid @map("account_id")
  userId                   String   @unique @db.Uuid @map("user_id") // Unique vì 1 User có 1 Account
  providerId               String?  @db.Uuid @map("provider_id") // Nullable nếu không dùng provider
  createdByAccountId       String?  @db.Uuid @map("created_by")
  username                 String   @unique
  password                 String
  state                   String   @default("INACTIVE")
  createdAt                DateTime @default(now()) @map("created_at")
  refreshTokenFromProvider String?  @map("refresh_token_from_provider")

  // Relations
  user      User      @relation(fields: [userId], references: [userId])
  provider  Provider? @relation(fields: [providerId], references: [providerId])
  sessions  Session[]
  
  // Self-relation: Ai tạo tài khoản này
  creator   Account?  @relation("AccountCreator", fields: [createdByAccountId], references: [accountId])
  created   Account[] @relation("AccountCreator")

  @@map("Account")
}

model Session {
  sessionId    String   @id @default(uuid()) @db.Uuid @map("session_id")
  accountId    String   @db.Uuid @map("account_id")
  deviceId     String?  @map("device_id")
  refreshToken String   @map("refresh_token")
  role         String
  createdAt    DateTime @default(now()) @map("created_at")
  expireAt     DateTime @map("expire_at")

  account Account @relation(fields: [accountId], references: [accountId])
  
  @@unique([accountId, deviceId], name: "accountId_deviceId")
  @@map("Session")
}

model Provider {
  providerId   String  @id @default(uuid()) @db.Uuid @map("provider_id")
  providerName String  @map("provider_name")
  refreshToken String? @map("refresh_token")

  accounts Account[]

  @@map("Provider")
}

// ==============================
// Province and Ward
// ==============================

model Province {
  code         Int        @id
  name         String
  divisionType String     @map("division_type")
  codename     String
  phoneCode    Int        @map("phone_code")

  wards    Ward[]

  // Các relation trả ngược về bảng User và CharityCampaign
  usersOrigin          User[]            @relation("OriginProvince")
  usersResidence       User[]            @relation("ResidenceProvince")
  campaignDestinations CharityCampaign[] @relation("CampaignDestinationProvince")

  @@map("Province")
}

model Ward {
  code         Int      @id
  name         String
  divisionType String   @map("division_type")
  codename     String
  
  provinceCode Int      @map("province_code")
  province     Province @relation(fields: [provinceCode], references: [code])

  // Các relation trả ngược về bảng User và CharityCampaign
  usersOrigin          User[]            @relation("OriginWard")
  usersResidence       User[]            @relation("ResidenceWard")
  campaignDestinations CharityCampaign[] @relation("CampaignDestinationWard")

  @@map("Ward")
}
